<!DOCTYPE html>
<html lang="mn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Korean Vocabulary Game</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      min-height:100vh;
      background:linear-gradient(135deg,#667eea,#764ba2);
      display:flex;
      justify-content:center;
      align-items:center;
      padding:20px;
      color:white;
    }

    .container{
      width:100%;
      max-width:900px;
      background:rgba(255,255,255,0.12);
      backdrop-filter:blur(10px);
      border-radius:25px;
      padding:25px;
      box-shadow:0 10px 30px rgba(0,0,0,0.3);
    }

    h1{
      text-align:center;
      margin-bottom:20px;
    }

    .menu{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
      gap:15px;
      margin-top:20px;
    }

    .lesson-btn{
      border:none;
      padding:18px;
      border-radius:15px;
      cursor:pointer;
      font-size:18px;
      font-weight:bold;
      color:white;
      background:linear-gradient(135deg,#ff9966,#ff5e62);
      transition:0.2s;
    }

    .lesson-btn:hover{
      transform:translateY(-4px);
    }

    .hidden{
      display:none;
    }

    .top-bar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      margin-bottom:20px;
      flex-wrap:wrap;
    }

    .score-box{
      background:rgba(255,255,255,0.15);
      padding:12px 18px;
      border-radius:12px;
      font-weight:bold;
    }

    .progress{
      width:100%;
      height:12px;
      background:rgba(255,255,255,0.2);
      border-radius:10px;
      overflow:hidden;
      margin-bottom:25px;
    }

    .progress-bar{
      height:100%;
      width:0%;
      background:linear-gradient(90deg,#00f260,#0575e6);
      transition:0.3s;
    }

    .question-box{
      text-align:center;
      background:rgba(255,255,255,0.12);
      border-radius:20px;
      padding:30px 20px;
    }

    .question{
      font-size:34px;
      font-weight:bold;
      margin-bottom:30px;
      line-height:1.5;
    }

    .choices{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:15px;
    }

    .choice-btn{
      border:none;
      padding:16px;
      border-radius:14px;
      cursor:pointer;
      background:white;
      color:#333;
      font-size:17px;
      font-weight:bold;
      transition:0.2s;
    }

    .choice-btn:hover{
      transform:scale(1.03);
    }

    .correct{
      background:#2ecc71 !important;
      color:white !important;
    }

    .wrong{
      background:#e74c3c !important;
      color:white !important;
    }

    .finish{
      text-align:center;
      padding:40px 20px;
    }

    .finish h2{
      font-size:40px;
      margin-bottom:20px;
    }

    .restart-btn{
      border:none;
      padding:15px 25px;
      border-radius:15px;
      background:linear-gradient(135deg,#00c6ff,#0072ff);
      color:white;
      font-size:18px;
      cursor:pointer;
      font-weight:bold;
      margin-top:20px;
    }

    @media(max-width:700px){

      .choices{
        grid-template-columns:1fr;
      }

      .question{
        font-size:26px;
      }

    }

  </style>
</head>

<body>

<div class="container">

  <div id="startScreen">

    <h1>🇰🇷 Korean Vocabulary Game</h1>

    <div class="menu">

      <button class="lesson-btn" onclick="startGame('Lesson 1')">
        📘 Хичээл 1
      </button>

      <button class="lesson-btn" onclick="startGame('Lesson 2')">
        📗 Хичээл 2
      </button>

      <button class="lesson-btn" onclick="startGame('Lesson 3')">
        📙 Хичээл 3
      </button>

      <button class="lesson-btn" onclick="startGame('All')">
        🎯 Бүгдийг хамт
      </button>

    </div>

  </div>

  <div id="gameScreen" class="hidden">

    <div class="top-bar">

      <div class="score-box">
        ✅ Оноо:
        <span id="score">0</span>
      </div>

      <div class="score-box">
        📚
        <span id="current">1</span> /
        <span id="total">0</span>
      </div>

    </div>

    <div class="progress">
      <div class="progress-bar" id="progressBar"></div>
    </div>

    <div class="question-box">

      <div class="question" id="question">
        Question
      </div>

      <div class="choices" id="choices"></div>

    </div>

  </div>

  <div id="finishScreen" class="hidden finish">

    <h2>🎉 Дууслаа!</h2>

    <p>
      Таны оноо:
      <strong id="finalScore"></strong>
    </p>

    <button class="restart-btn" onclick="goHome()">
      🔄 Дахин тоглох
    </button>

  </div>

</div>

<script>

const vocabulary = {

  "Lesson 1": [
    {"kr": "가져오다", "mn": "авчрах"},
    {"kr": "걱정", "mn": "санаа зовох"},
    {"kr": "남편", "mn": "нөхөр"},
    {"kr": "넣다", "mn": "хийх, оруулах"},
    {"kr": "닫다", "mn": "хаах"},
    {"kr": "댁", "mn": "өргөө"},
    {"kr": "들다", "mn": "өргөх, барих"},
    {"kr": "들어가다", "mn": "орох"},
    {"kr": "만지다", "mn": "тэмтрэх, имрэх, илэх"},
    {"kr": "먼저", "mn": "эхлээд"},
    {"kr": "명함", "mn": "нэрийн хуудас"},
    {"kr": "방문하다", "mn": "айлчлах"},
    {"kr": "벗다", "mn": "тайлах"},
    {"kr": "비슷하다", "mn": "адил, төстэй"},
    {"kr": "부하", "mn": "шадар, туслах"},
    {"kr": "사용하다", "mn": "хэрэглэх, ашиглах"},
    {"kr": "연락", "mn": "холбоо"},
    {"kr": "예절", "mn": "ёс жудаг"},
    {"kr": "올림", "mn": "хүндэтгэсэн..."},
    {"kr": "인사하다", "mn": "мэндлэх"},
    {"kr": "일찍", "mn": "эрт"}
  ],

  "Lesson 2": [
    {"kr": "감기", "mn": "ханиад"},
    {"kr": "갑자기", "mn": "гэнэт"},
    {"kr": "고치다", "mn": "засах"},
    {"kr": "광장", "mn": "талбай"},
    {"kr": "기다리다", "mn": "хүлээх"},
    {"kr": "만나다", "mn": "уулзах"}
  ],

  "Lesson 3": [
    {"kr": "가볍다", "mn": "хөнгөн"},
    {"kr": "계산하다", "mn": "тооцоо хийх"},
    {"kr": "교환하다", "mn": "солиулах"},
    {"kr": "귤", "mn": "жүрж"},
    {"kr": "기능", "mn": "үүрэг, ажиллагаа"}
  ]

};

let questions = [];
let currentQuestion = 0;
let score = 0;

function shuffle(array){

  for(let i=array.length-1; i>0; i--){

    const j = Math.floor(Math.random()*(i+1));

    [array[i], array[j]] = [array[j], array[i]];
  }

}

function startGame(lesson){

  if(lesson === "All"){

    questions = [
      ...vocabulary["Lesson 1"],
      ...vocabulary["Lesson 2"],
      ...vocabulary["Lesson 3"]
    ];

  }else{

    questions = [...vocabulary[lesson]];

  }

  shuffle(questions);

  currentQuestion = 0;
  score = 0;

  document.getElementById("startScreen").classList.add("hidden");
  document.getElementById("finishScreen").classList.add("hidden");
  document.getElementById("gameScreen").classList.remove("hidden");

  document.getElementById("total").textContent = questions.length;

  loadQuestion();

}

function loadQuestion(){

  if(currentQuestion >= questions.length){

    finishGame();
    return;

  }

  const q = questions[currentQuestion];

  document.getElementById("score").textContent = score;
  document.getElementById("current").textContent = currentQuestion + 1;

  const progress =
    (currentQuestion / questions.length) * 100;

  document.getElementById("progressBar").style.width =
    progress + "%";

  const showKorean = Math.random() > 0.5;

  let questionText;
  let correctAnswer;

  if(showKorean){

    questionText = q.kr;
    correctAnswer = q.mn;

  }else{

    questionText = q.mn;
    correctAnswer = q.kr;

  }

  document.getElementById("question").textContent =
    questionText;

  let options = [correctAnswer];

  while(options.length < 4){

    const random =
      questions[Math.floor(Math.random()*questions.length)];

    const option =
      showKorean ? random.mn : random.kr;

    if(!options.includes(option)){

      options.push(option);

    }

  }

  shuffle(options);

  const choicesDiv =
    document.getElementById("choices");

  choicesDiv.innerHTML = "";

  options.forEach(option => {

    const button =
      document.createElement("button");

    button.classList.add("choice-btn");

    button.textContent = option;

    button.onclick = () =>
      selectAnswer(button, option, correctAnswer);

    choicesDiv.appendChild(button);

  });

}

function selectAnswer(button, selected, correct){

  const buttons =
    document.querySelectorAll(".choice-btn");

  buttons.forEach(btn => btn.disabled = true);

  if(selected === correct){

    button.classList.add("correct");

    score++;

  }else{

    button.classList.add("wrong");

    buttons.forEach(btn => {

      if(btn.textContent === correct){

        btn.classList.add("correct");

      }

    });

  }

  setTimeout(() => {

    currentQuestion++;

    loadQuestion();

  }, 900);

}

function finishGame(){

  document.getElementById("gameScreen")
    .classList.add("hidden");

  document.getElementById("finishScreen")
    .classList.remove("hidden");

  document.getElementById("finalScore").textContent =
    score + " / " + questions.length;

}

function goHome(){

  document.getElementById("finishScreen")
    .classList.add("hidden");

  document.getElementById("startScreen")
    .classList.remove("hidden");

}

</script>

</body>
</html>
