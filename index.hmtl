    {kr:"라이터", mn:"асаагуур"},
    {kr:"마중을 나가다", mn:"тосч авахаар гарах"},
    {kr:"마중을 나오다", mn:"тосч авахаар ирэх"},
    {kr:"만나다", mn:"уулзах"},
