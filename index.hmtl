    {kr:"물세탁", mn:"усанд угаах"},
    {kr:"미술관", mn:"урлагийн галарей"},
    {kr:"바뀌다", mn:"өөрчлөгдөх, солигдох"},
    {kr:"박물관", mn:"музей"},
    {kr:"백화점", mn:"их дэлгүүр"},
    {kr:"변경", mn:"өөрчлөх"},
    {kr:"뷔페", mn:"буфет"},
    {kr:"빠지다", mn:"унах"},
    {kr:"손을 대다", mn:"гар хүрэх"},
    {kr:"쇼핑몰", mn:"худалдааны төв"},
    {kr:"안내 데스크", mn:"мэдээлэл өгөх газар"},
    {kr:"알다", mn:"мэдэх"},
    {kr:"약속하다", mn:"амлах, болзох"},
    {kr:"확인", mn:"нягтлах"},
    {kr:"회비", mn:"нийллэгний мөнгө"},
    {kr:"혜어지다", mn:"салах"},
    {kr:"호텔", mn:"зочид буудал"},
    {kr:"약속을 바꾸다", mn:"ам/бо өөрчлөх"},
    {kr:"약속을 못 지키다", mn:"амлалтаа биелүүлж чадахгүй"},
    {kr:"약속을 안 지키다", mn:"амлалтаа биелүүлэхгүй байх"},
    {kr:"점검하다", mn:"шалгалт хийх"},
    {kr:"정각", mn:"тогтсон цаг"},
    {kr:"정류장", mn:"автобусны буудал"},
    {kr:"준비물", mn:"бэлдэх зүйл"},
    {kr:"커피숍", mn:"кофешоп"},
    {kr:"피우다", mn:"татах"},
    {kr:"회의실", mn:"хурлын танхим"},
    {kr:"휴게실", mn:"амрах өрөө"},
    {kr:"약속을 지키다", mn:"ам/бо биелүүлэх"},
    {kr:"약속을 취소하다", mn:"ам/бо цуцлах"},
    {kr:"연락하다", mn:"холбоо барих"},
    {kr:"외출하다", mn:"гадагшаа гарах"},
    {kr:"유의 사항", mn:"анхаарах зүйл"},
    {kr:"잊다", mn:"мартах"},
    {kr:"절대", mn:"огт"}
  ],

  "Lesson 3": [
    {kr:"가볍다", mn:"хөнгөн"},
    {kr:"계산하다", mn:"тооцоо хийх"},
    {kr:"교환하다", mn:"солиулах"},
    {kr:"귤", mn:"жүрж"},
    {kr:"기능", mn:"үүрэг, ажиллагаа"},
    {kr:"기분", mn:"сэтгэл санаа"},
    {kr:"길다", mn:"урт"},
    {kr:"노트북", mn:"нөтбүк"},
    {kr:"누구나", mn:"хэн ч гэсэн"},
    {kr:"다양하다", mn:"олон янзийн, янз бүрийн"},
    {kr:"단순하다", mn:"энгийн"},
    {kr:"단어", mn:"үг"},
    {kr:"두껍다", mn:"зузаан"},
    {kr:"디자인", mn:"дизайн"},
    {kr:"마음에 들다", mn:"таалагдах"},
    {kr:"만", mn:"зөвхөн"},
    {kr:"많다", mn:"олон, их"},
    {kr:"맞다", mn:"таарах тохирох"},
    {kr:"멋있다", mn:"ганган, сайхан"},
    {kr:"무겁다", mn:"хүнд"},
    {kr:"바구니", mn:"сагс"},
    {kr:"벌", mn:"хослол / тоо.нэгж"},
    {kr:"봉지", mn:"уут"},
    {kr:"불편하다", mn:"тав тухгүй"},
    {kr:"빠르다", mn:"хурдан"},
    {kr:"상자", mn:"хайрцаг"},
    {kr:"샤프", mn:"харандаа"},
    {kr:"설악산", mn:"Сораг уул"},
    {kr:"송이", mn:"ширхэг/цэцэг"},
    {kr:"쇼핑몰", mn:"худалдааны төв"},
    {kr:"쉽게", mn:"амархан"},
    {kr:"슈퍼", mn:"супермаркет"},
    {kr:"신다", mn:"гутал өмсөх"},
    {kr:"싱겁다", mn:"давсгүй"},
    {kr:"싸다", mn:"ороох, боох"},
    {kr:"쌍", mn:"хос /ээмэг/"},
    {kr:"얇다", mn:"нимгэн"},
    {kr:"어울리다", mn:"зохих"},
    {kr:"유행하다", mn:"моодонд орох, дэлгэрэх"},
    {kr:"장", mn:"бага цөөн"},
    {kr:"적다", mn:"бутээгдэхүүн"},
    {kr:"제품", mn:"захиалах"},
    {kr:"주문하다", mn:"богино"},
    {kr:"짧다", mn:"эрэх хайх"},
    {kr:"찾다", mn:"карт"},
    {kr:"카드", mn:"хос / гутал"},
    {kr:"켤레", mn:"хос / гутал"},
    {kr:"톤톤하다", mn:"бат бөх, хатуу"},
    {kr:"팔다", mn:"зарах"},
    {kr:"편하다", mn:"тав тухтай"},
    {kr:"필요하다", mn:"хэрэгтэй"},
    {kr:"한라산", mn:"Халла уул"},
    {kr:"할인점", mn:"бөөний дэлгүүр"},
    {kr:"핸드백", mn:"гар цунх"},
    {kr:"화려하다", mn:"гял цал"},
    {kr:"환불하다", mn:"буцаах"}
  ],

  "Lesson 4": [
    {kr:"엑스레이", mn:"рентген зураг"},
    {kr:"냄비", mn:"хувин"}
  ]

};

let questions = [];
let currentQuestion = 0;
let score = 0;
let currentLesson = '';

function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
}

function startGame(lesson) {
  currentLesson = lesson;
  if (lesson === 'All') {
    questions = [
      ...vocabulary['Lesson 1'],
      ...vocabulary['Lesson 2'],
      ...vocabulary['Lesson 3'],
      ...vocabulary['Lesson 4']
    ];
  } else {
    questions = [...vocabulary[lesson]];
  }
  shuffle(questions);
  currentQuestion = 0;
  score = 0;
  document.getElementById('startScreen').classList.add('hidden');
  document.getElementById('finishScreen').classList.add('hidden');
  document.getElementById('gameScreen').classList.remove('hidden');
  document.getElementById('total').textContent = questions.length;
  loadQuestion();
}

function loadQuestion() {
  if (currentQuestion >= questions.length) { finishGame(); return; }
  const q = questions[currentQuestion];
  document.getElementById('score').textContent = score;
  document.getElementById('current').textContent = currentQuestion + 1;
  document.getElementById('progressBar').style.width = (currentQuestion / questions.length * 100) + '%';

  const showKorean = Math.random() > 0.5;
  const questionText = showKorean ? q.kr : q.mn;
  const correctAnswer = showKorean ? q.mn : q.kr;

  document.getElementById('questionLabel').textContent = showKorean ? '🇰🇷 СОЛОНГОС → МОНГОЛ' : '🇲🇳 МОНГОЛ → СОЛОНГОС';
  document.getElementById('question').textContent = questionText;

  // Build 4 unique options
  let pool = questions.map(x => showKorean ? x.mn : x.kr);
  let options = [correctAnswer];
  let tries = 0;
  while (options.length < 4 && tries < 200) {
    const candidate = pool[Math.floor(Math.random() * pool.length)];
    if (!options.includes(candidate)) options.push(candidate);
    tries++;
  }
  shuffle(options);

  const choicesDiv = document.getElementById('choices');
  choicesDiv.innerHTML = '';
  options.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    btn.textContent = opt;
    btn.onclick = () => selectAnswer(btn, opt, correctAnswer);
    choicesDiv.appendChild(btn);
  });
}

function selectAnswer(button, selected, correct) {
  document.querySelectorAll('.choice-btn').forEach(b => b.disabled = true);
  if (selected === correct) {
    button.classList.add('correct');
    score++;
  } else {
    button.classList.add('wrong');
    document.querySelectorAll('.choice-btn').forEach(b => {
      if (b.textContent === correct) b.classList.add('correct');
    });
  }
  setTimeout(() => { currentQuestion++; loadQuestion(); }, 950);
}

function finishGame() {
  document.getElementById('gameScreen').classList.add('hidden');
  document.getElementById('finishScreen').classList.remove('hidden');
  document.getElementById('finalScore').textContent = score + ' / ' + questions.length;
  const pct = score / questions.length;
  const msg = pct === 1 ? '🏆 Гайхалтай! Бүгдийг зөв!' :
              pct >= 0.8 ? '🌟 Маш сайн!' :
              pct >= 0.6 ? '👍 Сайн байна!' :
              '💪 Дахин давтаарай!';
  document.getElementById('finishMsg').textContent = msg;
}

function restartSame() {
  startGame(currentLesson);
}

function goHome() {
  document.getElementById('gameScreen').classList.add('hidden');
  document.getElementById('finishScreen').classList.add('hidden');
  document.getElementById('startScreen').classList.remove('hidden');
}
</script>
</body>
</html>
