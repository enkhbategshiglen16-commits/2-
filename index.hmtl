<!DOCTYPE html>
<html lang="mn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Korean Vocabulary Game</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700&family=Nunito:wght@600;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 20px;
      color: white;
      font-family: 'Nunito', sans-serif;
    }

    .container {
      width: 100%;
      max-width: 860px;
      margin-top: 20px;
    }

    /* ── HEADER ── */
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .header h1 {
      font-size: 2.4rem;
      font-weight: 900;
      background: linear-gradient(90deg, #e96cff, #48dbfb, #ff9f43);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -1px;
    }
    .header p { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-top: 4px; }

    /* ── LESSON GRID ── */
    .menu {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 14px;
    }

    .lesson-btn {
      border: none;
      padding: 22px 16px;
      border-radius: 18px;
      cursor: pointer;
      font-family: 'Nunito', sans-serif;
      font-size: 1.05rem;
      font-weight: 800;
      color: white;
      transition: transform .18s, box-shadow .18s;
      position: relative;
      overflow: hidden;
    }
    .lesson-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0);
      transition: background .18s;
    }
    .lesson-btn:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.4); }
    .lesson-btn:hover::after { background: rgba(255,255,255,0.08); }

    .btn-l1 { background: linear-gradient(135deg,#e96cff,#a855f7); }
    .btn-l2 { background: linear-gradient(135deg,#48dbfb,#0ea5e9); }
    .btn-l3 { background: linear-gradient(135deg,#ff9f43,#ef4444); }
    .btn-l4 { background: linear-gradient(135deg,#2ecc71,#16a34a); }
    .btn-all { background: linear-gradient(135deg,#f7971e,#ffd200); color: #1a1a2e; }

    .lesson-btn .count {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      opacity: 0.75;
      margin-top: 4px;
    }

    /* ── GAME SCREEN ── */
    .hidden { display: none !important; }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .score-box {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.15);
      padding: 10px 18px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 0.95rem;
      backdrop-filter: blur(6px);
    }

    .back-btn {
      border: none;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      color: white;
      padding: 10px 16px;
      border-radius: 12px;
      cursor: pointer;
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      transition: .18s;
    }
    .back-btn:hover { background: rgba(255,255,255,0.2); }

    .progress {
      width: 100%;
      height: 10px;
      background: rgba(255,255,255,0.12);
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 22px;
    }
    .progress-bar {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #e96cff, #48dbfb);
      border-radius: 10px;
      transition: width .4s ease;
    }

    .question-box {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 24px;
      padding: 36px 28px;
      text-align: center;
      backdrop-filter: blur(8px);
    }

    .question-label {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.4);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .question {
      font-size: 2.2rem;
      font-weight: 900;
      font-family: 'Noto Sans KR', 'Nunito', sans-serif;
      margin-bottom: 32px;
      line-height: 1.4;
      color: #fff;
      word-break: keep-all;
    }

    .choices {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .choice-btn {
      border: 2px solid rgba(255,255,255,0.15);
      padding: 16px 12px;
      border-radius: 16px;
      cursor: pointer;
      background: rgba(255,255,255,0.08);
      color: white;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      transition: transform .15s, background .15s, border-color .15s;
      word-break: keep-all;
      line-height: 1.4;
    }
    .choice-btn:hover:not(:disabled) {
      background: rgba(255,255,255,0.18);
      border-color: rgba(255,255,255,0.4);
      transform: scale(1.03);
    }
    .choice-btn.correct { background: #2ecc71 !important; border-color: #2ecc71 !important; color: white !important; transform: scale(1.05); }
    .choice-btn.wrong   { background: #e74c3c !important; border-color: #e74c3c !important; color: white !important; }

    /* ── FINISH ── */
    .finish {
      text-align: center;
      padding: 60px 20px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 24px;
      backdrop-filter: blur(8px);
    }
    .finish h2 { font-size: 3rem; margin-bottom: 10px; }
    .finish .result-score {
      font-size: 2rem;
      font-weight: 900;
      color: #ffd200;
      margin: 16px 0;
    }
    .finish p { color: rgba(255,255,255,0.6); margin-bottom: 30px; }

    .finish-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    .restart-btn {
      border: none;
      padding: 14px 28px;
      border-radius: 14px;
      background: linear-gradient(135deg,#48dbfb,#0ea5e9);
      color: white;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      transition: .18s;
    }
    .restart-btn:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }
    .home-btn {
      border: 2px solid rgba(255,255,255,0.3);
      padding: 14px 28px;
      border-radius: 14px;
      background: transparent;
      color: white;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      transition: .18s;
    }
    .home-btn:hover { background: rgba(255,255,255,0.1); }

    @media(max-width:600px){
      .choices { grid-template-columns: 1fr; }
      .question { font-size: 1.6rem; }
      .header h1 { font-size: 1.7rem; }
    }
  </style>
</head>
<body>
<div class="container">

  <!-- START -->
  <div id="startScreen">
    <div class="header">
      <h1>🇰🇷 Солонгос үгийн тоглоом</h1>
      <p>Хичээлээ сонгоод тоглоомоо эхлүүлээрэй</p>
    </div>
    <div class="menu">
      <button class="lesson-btn btn-l1" onclick="startGame('Lesson 1')">
        📘 Хичээл 1
        <span class="count">42 үг</span>
      </button>
      <button class="lesson-btn btn-l2" onclick="startGame('Lesson 2')">
        📗 Хичээл 2
        <span class="count">36 үг</span>
      </button>
      <button class="lesson-btn btn-l3" onclick="startGame('Lesson 3')">
        📙 Хичээл 3
        <span class="count">40 үг</span>
      </button>
      <button class="lesson-btn btn-l4" onclick="startGame('Lesson 4')">
        📕 Хичээл 4
        <span class="count">2+ үг</span>
      </button>
      <button class="lesson-btn btn-all" onclick="startGame('All')">
        🎯 Бүгдийг хамт
      </button>
    </div>
  </div>

  <!-- GAME -->
  <div id="gameScreen" class="hidden">
    <div class="top-bar">
      <button class="back-btn" onclick="goHome()">← Буцах</button>
      <div class="score-box">✅ Оноо: <span id="score">0</span></div>
      <div class="score-box">📚 <span id="current">1</span> / <span id="total">0</span></div>
    </div>
    <div class="progress"><div class="progress-bar" id="progressBar"></div></div>
    <div class="question-box">
      <div class="question-label" id="questionLabel">СОЛОНГОС → МОНГОЛ</div>
      <div class="question" id="question">Question</div>
      <div class="choices" id="choices"></div>
    </div>
  </div>

  <!-- FINISH -->
  <div id="finishScreen" class="hidden finish">
    <h2>🎉 Дууслаа!</h2>
    <div class="result-score"><span id="finalScore"></span></div>
    <p id="finishMsg"></p>
    <div class="finish-btns">
      <button class="restart-btn" onclick="restartSame()">🔄 Дахин тоглох</button>
      <button class="home-btn" onclick="goHome()">🏠 Эхний хуудас</button>
    </div>
  </div>

</div>

<script>
const vocabulary = {

  "Lesson 1": [
    {kr:"가져오다", mn:"авчрах"},
    {kr:"걱정", mn:"санаа зовох"},
    {kr:"남편", mn:"нөхөр"},
    {kr:"넣다", mn:"хийх, оруулах"},
    {kr:"닫다", mn:"хаах"},
    {kr:"댁", mn:"өргөө"},
    {kr:"들다", mn:"өргөх, барих"},
    {kr:"들어가다", mn:"орох"},
    {kr:"만지다", mn:"тэмтрэх, имрэх, илэх"},
    {kr:"먼저", mn:"эхлээд"},
    {kr:"명함", mn:"нэрийн хуудас"},
    {kr:"방문하다", mn:"айлчлах"},
    {kr:"벗다", mn:"тайлах"},
    {kr:"비슷하다", mn:"адил, төстэй"},
    {kr:"부하", mn:"шадар, туслах"},
    {kr:"사용하다", mn:"хэрэглэх, ашиглах"},
    {kr:"연락", mn:"холбоо"},
    {kr:"예절", mn:"ёс жудаг"},
    {kr:"올림", mn:"хүндэтгэсэн..."},
    {kr:"인사하다", mn:"мэндлэх"},
    {kr:"일찍", mn:"эрт"},
    {kr:"잘 먹겠습니다", mn:"сайхан хооллоорой"},
    {kr:"잘 먹었습니다", mn:"сайхан хооллолоо"},
    {kr:"정장", mn:"костюм пиджак"},
    {kr:"상담", mn:"зөвөлгөө"},
    {kr:"상담소", mn:"зөвөлгөө өгөх төв"},
    {kr:"상사", mn:"удирдах дээд албаны хүн"},
    {kr:"선배 / 후배", mn:"дээд / доод ангийн оюутан"},
    {kr:"설탕", mn:"элсэн чихэр"},
    {kr:"소개를 받다", mn:"танилцуулах"},
    {kr:"소개하다", mn:"танилцуулах"},
    {kr:"소리를 내다", mn:"хашхирах, дуу гаргах"},
    {kr:"손님", mn:"зочин"},
    {kr:"실례하겠습니다", mn:"уучлаарай"},
    {kr:"실례했습니다", mn:"уучлаарай"},
    {kr:"심심하다", mn:"уйтгарлах, гиюүрэх"},
    {kr:"씻다", mn:"угаах"},
    {kr:"아내", mn:"эхнэр"},
    {kr:"악수하다", mn:"гар барих"},
    {kr:"안내", mn:"танилцуулах, зааж өгөх"},
    {kr:"조심하다", mn:"болгоомжлох анхаарах"},
    {kr:"주인", mn:"эзэн"},
    {kr:"직원", mn:"ажилтан"},
    {kr:"찍다", mn:"зураг авах"},
    {kr:"초대를 받다", mn:"уригдах"},
    {kr:"초대하다", mn:"урих"},
    {kr:"켜다", mn:"асаах"},
    {kr:"크림", mn:"крем, тос"}
  ],

  "Lesson 2": [
    {kr:"감기", mn:"ханиад"},
    {kr:"갑자기", mn:"гэнэт"},
    {kr:"고치다", mn:"засах"},
    {kr:"과 사무실", mn:"тэнхим"},
    {kr:"광장", mn:"талбай"},
    {kr:"기다리다", mn:"хүлээх"},
    {kr:"길", mn:"зам"},
    {kr:"논문", mn:"дипломын ажил"},
    {kr:"늦다", mn:"оройтох, хоцрох"},
    {kr:"늦잠", mn:"орой босох"},
